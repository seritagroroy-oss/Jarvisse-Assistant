{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/(login|register|chat|create-checkout)",
      "destination": "server/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "public/$1"
    }
  ]
}
